{
  "name": "CardInvoice",
  "type": "object",
  "properties": {
    "card_id": {
      "type": "string",
      "description": "ID do cart\u00e3o de cr\u00e9dito"
    },
    "month": {
      "type": "string",
      "format": "date",
      "description": "M\u00eas de refer\u00eancia da fatura (YYYY-MM-01)"
    },
    "total_amount": {
      "type": "number",
      "description": "Total da fatura (soma das despesas)"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "closed",
        "paid",
        "overdue"
      ],
      "default": "open",
      "description": "Status da fatura"
    },
    "closing_date": {
      "type": "string",
      "format": "date",
      "description": "Data de fechamento da fatura"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "Data de vencimento da fatura"
    },
    "paid_date": {
      "type": "string",
      "format": "date",
      "description": "Data em que a fatura foi paga"
    },
    "paid_account_id": {
      "type": "string",
      "description": "ID da Conta Corrente utilizada para pagar a fatura"
    },
    "payable_id": {
      "type": "string",
      "description": "ID do Payable consolidado (Fatura [CART\u00c3O]) gerado no Contas a Pagar"
    },
    "transaction_id": {
      "type": "string",
      "description": "ID do lan\u00e7amento que quitou a fatura"
    },
    "notes": {
      "type": "string"
    },
    "family_id": {
      "type": "string"
    }
  },
  "required": [
    "card_id",
    "month"
  ],
  "rls": {
    "create": true,
    "read": {
      "family_id": "{{user.family_id}}"
    },
    "update": {
      "family_id": "{{user.family_id}}"
    },
    "delete": {
      "family_id": "{{user.family_id}}"
    }
  }
}